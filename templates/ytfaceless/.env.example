# === Required: OpenRouter (free AI models for script generation) ===
OPENROUTER_API_KEY=sk-or-...  # Get free key at https://openrouter.ai/keys

# === Required: YouTube OAuth (one-time manual setup) ===
YOUTUBE_CLIENT_ID=...
YOUTUBE_CLIENT_SECRET=...
YOUTUBE_REDIRECT_URI=http://localhost:3001/api/youtube/callback

# === Required: Vercel Cron ===
CRON_SECRET=...  # Generate with: openssl rand -hex 32

# === Required: Vercel Blob (file storage) ===
BLOB_READ_WRITE_TOKEN=...

# === Required: Vercel KV (database) ===
KV_REST_API_URL=...
KV_REST_API_TOKEN=...

# === Optional: OpenAI (for enhanced script generation) ===
# OPENAI_API_KEY=sk-...  # Only if you want GPT-4o instead of free models

# === Optional: Runway (for AI video generation) ===
# RUNWAY_API_KEY=...  # Only if you want real AI video instead of HTML-based

# === Optional: ElevenLabs (for AI voiceover) ===
# ELEVENLABS_API_KEY=...  # Only if you want real AI voice instead of script files
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
